{
  "name": "@chanom/logger",
  "version": "0.0.0",
  "description": "Tiny, zero-dependency, provider-agnostic logger for web apps: fan records out to the console or your own provider, gated by an enabled switch and log-level filtering.",
  "keywords": [
    "console",
    "logger",
    "logging",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peeranat-dan/chanom.git",
    "directory": "packages/logger"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsdown"
  },
  "devDependencies": {
    "@chanom/dev-config": "workspace:*",
    "@tsconfig/node-lts": "catalog:",
    "@tsconfig/node-ts": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
